{
  "expo": {
    "name": "HappiHarbor",
    "slug": "happiharbor-mobile",
    "scheme": "happiharbor",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F8F4EE"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.happiharbor-mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8F4EE"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
